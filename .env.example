# Copy to .env.local and set real values. Never commit .env.local.

ADMIN_EMAIL=
ADMIN_PASSWORD=

# MongoDB Atlas — use Database Users (not your Atlas login). If login fails with "bad auth":
# reset the DB user password in Atlas → Database Access → edit user → Edit Password,
# then paste the new password into the URI. Characters like @ : / ? # must be percent-encoded
# in USER and PASS (e.g. @ → %40). Build URI from Atlas "Connect" → Drivers → copy string.
MONGODB_URI=
# Default database name for app data (orders, etc.)
MONGODB_DB_NAME=lucky-prairie
